# =============================================================================
# PrintFlowLite Docker Environment Variables
# =============================================================================
# These environment variables are consumed by the PrintFlowLite server
# inside the container. Variable names use the PFL_NS prefix.
#
# The PFL_ prefix is mapped to PrintFlowLite server.properties keys by
# replacing dots with underscores in the key name.
#
# Example: PFL_SRV_visitor.organization → server.properties visitor.organization
# =============================================================================

# -----------------------------------------------------------------------------
# IMPORTANT: Container Detection (required)
# -----------------------------------------------------------------------------
# SP_CONTAINER=DOCKER must be set for PrintFlowLite to detect it is running
# inside a container and adjust accordingly.
PFL_CONTAINER=DOCKER

# -----------------------------------------------------------------------------
# Namespace prefix (do not change)
# -----------------------------------------------------------------------------
PRINTFLOWLITE_NS=PFL_

# -----------------------------------------------------------------------------
# Visitor / Organization
# -----------------------------------------------------------------------------
# Shown on the login page and in email notifications.
# Uncomment and set your organization name:
# PFL_SRV_01=visitor.organization:My Organization Name

# -----------------------------------------------------------------------------
# Server Ports
# -----------------------------------------------------------------------------
# HTTP is disabled in Docker (redirect to HTTPS only).
# HTTPS uses port 8632 inside container, mapped to 8643 on host.
PFL_SRV_01=server.port:0
PFL_SRV_02=server.ssl.port:8632

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# These values must match docker-compose.yml postgres service.
PFL_SRV_10=database.type:PostgreSQL
PFL_SRV_11=database.driver:org.postgresql.Driver
PFL_SRV_12=database.url:jdbc:postgresql://printflowlite-postgres:5432/printflowlite
PFL_SRV_13=database.user:printflowlite
PFL_SRV_14=database.password:change-me-in-docker-env

# Database connection pool (adjust for production)
PFL_SRV_20=database.connection.pool.max:50
PFL_SRV_21=database.connection.pool.min:5

# -----------------------------------------------------------------------------
# HTTPS / SSL
# -----------------------------------------------------------------------------
# The container uses a self-signed SSL certificate by default.
# For production, provide your own keystore via a volume mount:
# PFL_SRV_30=server.ssl.keystore:custom/my-keystore.jks
# PFL_SRV_31=server.ssl.keystore-password:your-password
# PFL_SRV_32=server.ssl.key-password:your-key-password

# -----------------------------------------------------------------------------
# CUPS Configuration
# -----------------------------------------------------------------------------
# CUPS server port (localhost inside container)
PFL_SRV_40=cups.server.port:631

# -----------------------------------------------------------------------------
# Mail / SMTP
# -----------------------------------------------------------------------------
# Uncomment and configure for email notifications:
# PFL_SRV_50=mail.smtp.host:smtp.example.com
# PFL_SRV_51=mail.smtp.port:587
# PFL_SRV_52=mail.smtp.tls:Y
# PFL_SRV_53=mail.smtp.auth:Y
# PFL_SRV_54=mail.smtp.username:your-username
# PFL_SRV_55=mail.smtp.password:your-password
# PFL_SRV_56=mail.smtp.from:noreply@example.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Set log level: ERROR, WARN, INFO, DEBUG
# PFL_SRV_60=log4j.rootLogger:INFO

# -----------------------------------------------------------------------------
# Session Timeout (in minutes)
# -----------------------------------------------------------------------------
PFL_SRV_70=server.session.timeout:30

# -----------------------------------------------------------------------------
# Thread Pool
# -----------------------------------------------------------------------------
PFL_SRV_80=server.threadpool.maxthreads:100
PFL_SRV_81=server.threadpool.minthreads:10
PFL_SRV_82=server.threadpool.queue.capacity:1000

# -----------------------------------------------------------------------------
# Advanced: Proxy Print Settings
# -----------------------------------------------------------------------------
# PFL_SRV_90=server.proxyprint.default.duplicate:false
# PFL_SRV_91=server.proxyprint.default.duplex:N

# -----------------------------------------------------------------------------
# Maintenance Mode
# -----------------------------------------------------------------------------
# Uncomment to enable maintenance mode (blocks all access except admin):
# PFL_SRV_99=system.maintenance:Y
