# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{xml,xsl,xslt,xjb}]
indent_size = 2

[*.{json,yaml,yml}]
indent_size = 2

[*.{css,less,scss}]
indent_size = 2

[*.{js,jsx}]
indent_size = 2

[*.{java}]
indent_size = 4

[*.sh]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{pom,pom.xml}]
indent_size = 2
