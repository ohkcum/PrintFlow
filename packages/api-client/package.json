{
  "name": "@printflow/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./trpc": {
      "import": "./dist/trpc-client.js",
      "types": "./dist/trpc-client.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.72.2",
    "@trpc/client": "^11.1.0",
    "@trpc/react-query": "^11.1.0",
    "@trpc/server": "^11.1.0",
    "@printflow/common": "workspace:*",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@printflow/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "react": "^19.0.0",
    "vitest": "^3.1.1"
  }
}
