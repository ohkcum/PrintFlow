# PrintFlow Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================
# APP
# ============================================
NODE_ENV=development
LOG_LEVEL=info
PORT=3001

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://printflow:password@localhost:5432/printflow
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# AUTH
# ============================================
AUTH_SECRET=your-auth-secret-min-32-chars-here
AUTH_EXPIRES_IN=7d
TOTP_ISSUER=PrintFlow

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# STORAGE
# ============================================
DOCUMENT_STORAGE_PATH=./data/documents
THUMBNAIL_STORAGE_PATH=./data/thumbnails

# ============================================
# PRINT / IPP
# ============================================
IPP_SERVER_PORT=6310
CUPS_HOST=localhost
CUPS_PORT=631

# ============================================
# EMAIL
# ============================================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@printflow.local
IMAP_HOST=localhost
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# ============================================
# LIBSOFFICE (for document conversion)
# ============================================
SOFFICE_PATH=/usr/bin/soffice

# ============================================
# FRONTEND URL
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
